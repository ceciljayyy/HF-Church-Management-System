generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
enum UserStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  VISITOR
}

enum MembershipType {
  BAPTIZED
  UNBAPTIZED
  TRANSFER
  OTHER
}

enum GroupType {
  MINISTRY
  DEPARTMENT
  CELL
  SMALL_GROUP
  OTHER
}

enum GroupStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum EventType {
  SERVICE
  MEETING
  CONFERENCE
  OUTREACH
  YOUTH
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum AttendanceMode {
  MANUAL
  KIOSK
  QR
  SELF
}

enum AttendanceRecordStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ContributionType {
  TITHE
  OFFERING
  DONATION
  THANKSGIVING
  SEED
  BUILDING_FUND
  WELFARE
  MISSIONS
  SPECIAL_PROJECT
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  CHEQUE
  OTHER
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum PledgeStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
}

enum FundStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ReceiptStatus {
  ISSUED
  VOID
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum ScopeType {
  GLOBAL
  DEPARTMENT
  SELF
  NONE
}

enum PermissionEffect {
  ALLOW
  DENY
}

model Church {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  email     String?  @unique
  phone     String?
  website   String?
  address   String?
  city      String?
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]

  @@index([name])
}

model Branch {
  id           String   @id @default(cuid())
  churchId     String
  name         String
  address      String?
  phone        String?
  email        String?
  pastorName   String?
  isMainBranch Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  church             Church              @relation(fields: [churchId], references: [id], onDelete: Cascade)
  users              User[]
  people             Person[]
  members            Member[]
  families           Family[]
  groups             Group[]
  events             Event[]
  attendanceSessions AttendanceSession[]
  financialFunds     FinancialFund[]
  contributions      Contribution[]
  expenses           Expense[]
  pledges            Pledge[]
  pledgePayments     PledgePayment[]
  receipts           Receipt[]
  settings           Setting[]
  churchProfile      ChurchProfile?
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]

  @@unique([churchId, name])
  @@index([churchId])
  @@index([name])
}

model User {
  id           String     @id @default(cuid())
  branchId     String
  personId     String?    @unique
  name         String
  username     String?    @unique
  email        String     @unique
  phone        String?
  passwordHash String
  mustChangePassword Boolean @default(false)
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  branch                    Branch              @relation(fields: [branchId], references: [id])
  person                    Person?             @relation(fields: [personId], references: [id], onDelete: SetNull)
  roles                     UserRole[]
  permissionOverrides       UserPermissionOverride[] @relation("UserPermissionOverrides")
  grantedPermissionOverrides UserPermissionOverride[] @relation("UserPermissionOverrideGrants")
  createdEvents             Event[]             @relation("EventCreatedBy")
  attendanceSessionsCreated AttendanceSession[] @relation("AttendanceSessionCreatedBy")
  attendanceCheckedIn       AttendanceRecord[]  @relation("AttendanceCheckedInBy")
  contributionsReceived     Contribution[]      @relation("ContributionReceivedBy")
  expensesRequested         Expense[]           @relation("ExpenseRequestedBy")
  expensesApproved          Expense[]           @relation("ExpenseApprovedBy")
  pledgePaymentsReceived    PledgePayment[]     @relation("PledgePaymentReceivedBy")
  auditLogs                 AuditLog[]
  activityLogs              ActivityLog[]
  churchProfilesCreated     ChurchProfile[]     @relation("ChurchProfileCreatedBy")
  churchProfilesUpdated     ChurchProfile[]     @relation("ChurchProfileUpdatedBy")

  @@index([branchId])
  @@index([personId])
  @@index([status])
}

model ChurchProfile {
  id                              String    @id @default(cuid())
  branchId                        String    @unique
  churchName                      String
  branchName                      String?
  denomination                    String?
  slogan                          String?
  website                         String?
  logoUrl                         String?
  phone                           String
  alternatePhone                  String?
  email                           String
  adminContactName                String
  adminContactPhone               String
  adminContactEmail               String?
  seniorPastorName                String?
  streetAddress                   String?
  city                            String
  stateOrRegion                   String?
  postalCode                      String?
  country                         String    @default("Ghana")
  latitude                        Float?
  longitude                       Float?
  mapProvider                     String?
  language                        String    @default("English")
  timezone                        String    @default("Africa/Accra")
  distanceUnit                    String    @default("kilometers")
  currency                        String    @default("GHS")
  dateFormat                      String    @default("DD/MM/YYYY")
  defaultCity                     String?
  defaultStateOrRegion            String?
  defaultPostalCode               String?
  defaultCountry                  String    @default("Ghana")
  defaultServiceDay               String    @default("Sunday")
  defaultServiceTime              String    @default("09:00")
  enableChildrenServiceAttendance Boolean   @default(true)
  enableVehicleCount              Boolean   @default(true)
  welfareInitialPayment           Decimal   @default(10) @db.Decimal(14, 2)
  welfareMonthlyPayment           Decimal   @default(5) @db.Decimal(14, 2)
  onboardingCompleted             Boolean   @default(false)
  onboardingCompletedAt           DateTime?
  createdById                     String?
  updatedById                     String?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("ChurchProfileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("ChurchProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([churchName])
  @@index([onboardingCompleted])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  name        String?
  description String?
  module      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
  userOverrides UserPermissionOverride[]
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  scopeType ScopeType @default(GLOBAL)
  scopeId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([scopeType])
  @@index([scopeId])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserPermissionOverride {
  id           String           @id @default(cuid())
  userId       String
  permissionId String
  effect       PermissionEffect
  scopeType    ScopeType        @default(GLOBAL)
  scopeId      String?
  reason       String?
  grantedById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user      User       @relation("UserPermissionOverrides", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy User?      @relation("UserPermissionOverrideGrants", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId, scopeType, scopeId])
  @@index([userId])
  @@index([permissionId])
  @@index([effect])
  @@index([scopeType])
}

model Person {
  id              String    @id @default(cuid())
  branchId        String
  title           String?
  firstName       String
  middleName      String?
  lastName        String
  preferredName   String?
  suffix          String?
  gender          Gender?
  dateOfBirth     DateTime?
  hideAge         Boolean   @default(false)
  phone           String?
  homePhone       String?
  mobilePhone     String?
  workPhone       String?
  email           String?   @unique
  otherEmail      String?
  address         String?
  city            String?
  occupation      String?
  facebookUrl     String?
  xUrl            String?
  linkedinUrl     String?
  classification  String?
  familyRole      String?
  friendDate      DateTime?
  profilePhotoUrl String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  branch            Branch             @relation(fields: [branchId], references: [id])
  member            Member?
  familyMembers     FamilyMember[]
  ledGroups         Group[]            @relation("GroupLeader")
  groupMemberships  GroupMember[]
  contributions     Contribution[]
  pledges           Pledge[]
  attendanceRecords AttendanceRecord[]
  platformUser      User?

  @@index([branchId])
  @@index([firstName, lastName])
  @@index([lastName])
  @@index([classification])
  @@index([createdAt])
  @@index([deletedAt])
}

model Member {
  id                    String         @id @default(cuid())
  branchId              String
  personId              String         @unique
  membershipNumber      String         @unique
  status                MemberStatus   @default(ACTIVE)
  joinedAt              DateTime?
  membershipType        MembershipType @default(OTHER)
  baptismStatus         String?
  maritalStatus         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  deletedAt             DateTime?

  branch Branch @relation(fields: [branchId], references: [id])
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([status])
}

model Family {
  id           String    @id @default(cuid())
  branchId     String
  familyName   String
  address      String?
  primaryPhone String?
  primaryEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  branch  Branch         @relation(fields: [branchId], references: [id])
  members FamilyMember[]

  @@unique([branchId, familyName])
  @@index([branchId])
}

model FamilyMember {
  id             String  @id @default(cuid())
  familyId       String
  personId       String
  relationship   String
  isHeadOfFamily Boolean @default(false)

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([familyId, personId])
  @@index([familyId])
  @@index([personId])
}

model Group {
  id          String      @id @default(cuid())
  branchId    String
  name        String
  type        GroupType   @default(OTHER)
  description String?
  leaderId    String?
  meetingDay  String?
  meetingTime String?
  location    String?
  status      GroupStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  branch  Branch        @relation(fields: [branchId], references: [id])
  leader  Person?       @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members GroupMember[]

  @@unique([branchId, name])
  @@index([branchId])
  @@index([name])
  @@index([status])
  @@index([type])
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  personId String
  role     String?
  joinedAt DateTime @default(now())
  status   String   @default("ACTIVE")

  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([groupId, personId])
  @@index([groupId])
  @@index([personId])
}

model Event {
  id            String      @id @default(cuid())
  branchId      String
  title         String
  description   String?
  eventType     EventType   @default(OTHER)
  startDateTime DateTime
  endDateTime   DateTime
  location      String?
  capacity      Int?
  status        EventStatus @default(DRAFT)
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  branch    Branch              @relation(fields: [branchId], references: [id])
  createdBy User?               @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sessions  AttendanceSession[]

  @@unique([branchId, title, startDateTime])
  @@index([branchId])
  @@index([status])
  @@index([startDateTime])
}

model AttendanceSession {
  id          String         @id @default(cuid())
  branchId    String
  eventId     String?
  title       String
  sessionDate DateTime
  checkInMode AttendanceMode @default(MANUAL)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  branch    Branch             @relation(fields: [branchId], references: [id])
  event     Event?             @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdBy User?              @relation("AttendanceSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  records   AttendanceRecord[]

  @@unique([branchId, title, sessionDate])
  @@index([branchId])
  @@index([sessionDate])
}

model AttendanceRecord {
  id            String                 @id @default(cuid())
  sessionId     String
  personId      String
  status        AttendanceRecordStatus @default(PRESENT)
  checkedInAt   DateTime               @default(now())
  checkedInById String?
  notes         String?

  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  person      Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  checkedInBy User?             @relation("AttendanceCheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)

  @@unique([sessionId, personId])
  @@index([sessionId])
  @@index([personId])
  @@index([checkedInAt])
}

model FinancialFund {
  id             String     @id @default(cuid())
  branchId       String
  name           String
  description    String?
  openingBalance Decimal    @default(0) @db.Decimal(14, 2)
  restricted     Boolean    @default(false)
  status         FundStatus @default(ACTIVE)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  contributions Contribution[]
  expenses      Expense[]
  pledges       Pledge[]

  @@unique([branchId, name])
  @@index([branchId])
  @@index([status])
}

model Contribution {
  id               String           @id @default(cuid())
  branchId         String
  contributionNumber String?
  personId         String?
  contributorName  String?
  isAnonymous      Boolean          @default(false)
  fundId           String?
  type             ContributionType @default(OFFERING)
  amount           Decimal          @db.Decimal(14, 2)
  currency         String           @default("GHS")
  paymentMethod    PaymentMethod    @default(CASH)
  paymentReference String?
  reference        String?          @unique
  contributionDate DateTime
  receivedById     String?
  receivedByName   String?
  notes            String?
  receiptNumber    String?
  status           String           @default("RECORDED")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  branch     Branch         @relation(fields: [branchId], references: [id])
  person     Person?        @relation(fields: [personId], references: [id], onDelete: SetNull)
  fund       FinancialFund? @relation(fields: [fundId], references: [id], onDelete: SetNull)
  receivedBy User?          @relation("ContributionReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  receipts   Receipt[]

  @@index([branchId])
  @@index([type])
  @@index([contributionDate])
}

model Expense {
  id            String        @id @default(cuid())
  branchId      String
  expenseNumber String?
  category      String
  title         String
  description   String?
  fundId        String?
  amount        Decimal       @db.Decimal(14, 2)
  currency      String        @default("GHS")
  paymentMethod PaymentMethod @default(CASH)
  vendorName    String?
  expenseDate   DateTime
  dueDate       DateTime?
  requestedById String?
  requestedByName String?
  approvedById  String?
  approvedByName String?
  status        ExpenseStatus @default(PENDING)
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  branch      Branch @relation(fields: [branchId], references: [id])
  fund        FinancialFund? @relation(fields: [fundId], references: [id], onDelete: SetNull)
  requestedBy User?  @relation("ExpenseRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy  User?  @relation("ExpenseApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([branchId, title, expenseDate])
  @@index([branchId])
  @@index([fundId])
  @@index([status])
}

model Pledge {
  id              String       @id @default(cuid())
  branchId        String
  pledgeNumber    String?
  title           String
  contributorId   String?
  contributorName String
  fundId          String?
  targetAmount    Decimal      @db.Decimal(14, 2)
  currency        String       @default("GHS")
  startDate       DateTime
  dueDate         DateTime
  status          PledgeStatus @default(ACTIVE)
  note            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  branch   Branch          @relation(fields: [branchId], references: [id])
  person   Person?         @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  fund     FinancialFund?  @relation(fields: [fundId], references: [id], onDelete: SetNull)
  payments PledgePayment[]

  @@index([branchId])
  @@index([fundId])
  @@index([status])
  @@index([dueDate])
}

model PledgePayment {
  id            String        @id @default(cuid())
  branchId      String
  pledgeId      String
  amount        Decimal       @db.Decimal(14, 2)
  currency      String        @default("GHS")
  paymentMethod PaymentMethod @default(CASH)
  paymentDate   DateTime
  reference     String?
  receivedById  String?
  receivedByName String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id])
  pledge     Pledge @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  receivedBy User?  @relation("PledgePaymentReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  receipt    Receipt?

  @@index([branchId])
  @@index([pledgeId])
  @@index([paymentDate])
}

model Receipt {
  id              String        @id @default(cuid())
  branchId        String
  receiptNumber   String        @unique
  contributionId  String?
  pledgePaymentId String?       @unique
  amount          Decimal       @db.Decimal(14, 2)
  currency        String        @default("GHS")
  issuedTo        String
  issuedAt        DateTime      @default(now())
  status          ReceiptStatus @default(ISSUED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  contribution  Contribution?  @relation(fields: [contributionId], references: [id], onDelete: SetNull)
  pledgePayment PledgePayment? @relation(fields: [pledgePaymentId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([issuedAt])
}

model Setting {
  id        String      @id @default(cuid())
  branchId  String
  key       String
  value     Json
  type      SettingType @default(STRING)
  updatedAt DateTime    @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, key])
}

model AuditLog {
  id        String   @id @default(cuid())
  branchId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([entity, entityId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  branchId    String
  userId      String?
  title       String
  description String?
  type        String
  createdAt   DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([branchId])
}
